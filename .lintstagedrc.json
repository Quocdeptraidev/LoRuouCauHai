{
  "apps/frontend/**/*.{ts,tsx}": [
    "npx prettier --write --config apps/frontend/.prettierrc",
    "npx eslint --fix"
  ],
  "apps/backend/**/*.py": [
    "node scripts/python-exec.mjs -m ruff format",
    "node scripts/python-exec.mjs -m ruff check --fix",
    "node scripts/python-exec.mjs -m mypy apps/backend/app"
  ]
}
